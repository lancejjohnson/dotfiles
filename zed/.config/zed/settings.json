// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "agent_buffer_font_size": 17.0,
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "auto",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "tree_view": false,
    "dock": "left",
  },
  "document_symbols": "on",
  "hard_tabs": false,
  "edit_predictions": {
    "provider": "none",
  },
  "agent": {
    "use_modifier_to_send": true,
    "dock": "right",
    "default_profile": "ask",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-latest",
    },
  },
  "agent_ui_font_size": 17.0,
  "base_keymap": "VSCode",
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_features": {
    "calt": false,
    "liga": false,
    "dlig": false,
    // "calt": false,
    // "liga": false,
    // ss02: script when true
    // "ss02": false,
    // ss04: unstyled g when true
    // "ss04": false,
    // ss15: no serif i when true
    // "ss15": true,
    // ss16: no serif r when true
    // "ss16": true,
  },
  "buffer_font_size": 17.0,
  "buffer_font_weight": 400.0,
  "experimental.theme_overrides": {
    "syntax": {
      "comment": {
        "font_style": "italic",
      },
      "comment.doc": {
        "font_style": "italic",
      },
    },
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
    "git_gutter": "hide",
  },
  "languages": {
    "Elixir": {
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
      "format_on_save": "on",
      "language_servers": ["expert", "!lexical", "!elixir-ls", "!next-ls"],
    },
    "HEEx": {
      "formatter": {
        "external": {
          "command": "mix",
          "arguments": ["format", "--stdin-filename", "{buffer_path}", "-"],
        },
      },
      "format_on_save": "on",
      "language_servers": ["expert", "!lexical", "!elixir-ls", "!next-ls"],
    },
    "JavaScript": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" },
      ],
      "language_servers": [
        "biome",
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
    },
    "TypeScript": {
      "prettier": { "allowed": false },
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" },
      ],
      "language_servers": [
        "biome",
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint",
      ],
    },
    // Zed doesn't recognize JSX as a language
    // "JSX": {
    //   "formatter": [
    //     { "language_server": { "name": "biome" } },
    //     { "code_action": "source.organizeImports.biome" },
    //     { "code_action": "source.fixAll.biome" },
    //   ],
    // },
    "TSX": {
      "formatter": [
        { "language_server": { "name": "biome" } },
        { "code_action": "source.organizeImports.biome" },
        { "code_action": "source.fixAll.biome" },
      ],
    },
    "JSON": {
      "formatter": [{ "language_server": { "name": "biome" } }],
    },
    "CSS": {
      "formatter": [{ "language_server": { "name": "biome" } }],
    },
    "Ruby": {
      "language_servers": ["ruby-lsp", "!solargraph", "!rubocop"],
      "formatter": "language_server",
    },
  },
  "lsp": {
    "ruby-lsp": {
      "initialization_options": {
        "enabledFeatures": {
          "diagnostics": false,
          "formatting": true,
        },
        "formatter": "standard",
      },
    },
    "biome": {
      "settings": {
        "require_config_file": true,
      },
    },
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": [
            "\\.className\\s*[+]?=\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttributeNS\\(.*,\\s*['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttribute\\(['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.add\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.remove\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.toggle\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.contains\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\(\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\([^,)]+,\\s*['\"]([^'\"]*)['\"]",
          ],
        },
      },
    },
  },
  "relative_line_numbers": "enabled",
  "format_on_save": "on",
  "soft_wrap": "none",
  "tab_size": 2,
  "tab_bar": {
    // Whether or not to show the tab bar in the editor
    "show": true,
    // Whether or not to show the navigation history buttons.
    "show_nav_history_buttons": true,
  },
  // "theme": "Github Light",
  "theme": "Gruvbox Light Hard",
  "ui_font_size": 16,
  "vim_mode": true,
  "current_line_highlight": "gutter",
  "pane_split_direction_horizontal": "down",
  "pane_split_direction_vertical": "right",
}
